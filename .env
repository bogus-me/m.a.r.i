########################################
# 🌐 PLEX VERBINDUNG
########################################
PLEX_URL=https://deine.server.ip:dein.port
PLEX_TOKEN=dein plex token aus der media info xml


########################################
# 🕒 ZEITPLANUNG
########################################
REFRESH_INTERVAL_DAYS=1
REFRESH_TIME=05:00
MAX_ITEMS_PER_SCAN=50


########################################
# 🧾 LOGGING & DATEIEN
########################################
LOG_FILE=/app/last_refresh.log
LOG_MAX_LINES=500
HEALTH_FILE=/app/health_status.txt
MSG_STATE_FILE=/app/msg_ids.json
REFRESH_DB_PATH=/app/refresh_state.db


########################################
# ❤️ HEALTHCHECK
########################################
HEALTHCHECK_MAX_DAYS=5
HEALTHCHECK_INTERVAL_MINUTES=60


########################################
# 💬 DISCORD-BOT
########################################
ENABLE_DISCORD_NOTIFY=true
DISCORD_TOKEN=DEIN_DISCORD_BOT_TOKEN
DISCORD_CHANNEL_ID=DEINE_DISCORD_CHANNEL_ID


########################################
# 💬 TELEGRAM-BOT
########################################
ENABLE_TELEGRAM_NOTIFY=false
TELEGRAM_BOT_TOKEN=DEIN_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=DEINE_TELEGRAM_CHAT_ID

